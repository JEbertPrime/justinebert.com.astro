---
interface Props {
  endpoint?: string;
  title?: string;
  description?: string;
}

const {
  endpoint = "/api/mcp",
  title = "MCP Playground",
  description,
} = Astro.props;
---

<section
  class="mcp-playground"
  aria-label={`${title} playground`}
  data-mcp-playground
  data-endpoint={endpoint}
>
  <h2>{title}</h2>
  {description && <p>{description}</p>}

  <!-- Server URL + connect -->
  <div class="row">
    <label class="label-inline">
      Server URL
      <input
        data-ref="endpoint-input"
        type="url"
        value={endpoint}
        spellcheck="false"
        placeholder="https://…/mcp"
      />
    </label>
    <span data-ref="badge" class="badge badge-idle" aria-live="polite"
      >Disconnected</span
    >
    <button data-ref="btn-connect">Connect</button>
    <button data-ref="btn-disconnect" disabled>Disconnect</button>
  </div>

  <!-- Server info -->
  <div data-ref="server-info" class="server-info" aria-live="polite"></div>

  <!-- Tools -->
  <div data-ref="tools-section" hidden>
    <h3>Tools</h3>
    <ul data-ref="tools-list" class="tools-list"></ul>
  </div>

  <!-- Call form -->
  <div data-ref="call-section" hidden>
    <h3>Call a tool</h3>
    <div class="row">
      <label class="label-inline">
        Tool
        <select data-ref="tool-name"></select>
      </label>
    </div>

    <!-- Schema-driven argument fields -->
    <div data-ref="arg-fields" class="arg-fields"></div>

    <!-- Raw JSON fallback (shown when no schema / schema is empty) -->
    <div data-ref="raw-row" class="row" hidden>
      <label class="label-inline">
        Arguments (JSON)
        <input data-ref="tool-args" type="text" value="{}" spellcheck="false" />
      </label>
    </div>

    <button data-ref="btn-call">Call</button>
  </div>

  <!-- Log -->
  <h3>Log</h3>
  <div
    data-ref="log"
    class="log"
    role="log"
    aria-live="polite"
    aria-label="Activity log"
  >
  </div>
</section>

<script>
  import { MCPClient, type Tool } from "simple-browser-mcp-client";

  // ── Schema types ──────────────────────────────────────────────────────────
  type PropSchema =
    | {
        type: "string";
        default?: string;
        enum?: string[];
        oneOf?: Array<{ const: string; title: string }>;
      }
    | {
        type: "number" | "integer";
        default?: number;
        minimum?: number;
        maximum?: number;
      }
    | { type: "boolean"; default?: boolean }
    | { type: "array"; default?: unknown[] }
    | {
        type: "object";
        properties?: Record<string, PropSchema>;
        default?: unknown;
      };

  interface InputSchema {
    type: "object";
    properties?: Record<string, PropSchema>;
    required?: string[];
  }

  // ── Schema utilities ──────────────────────────────────────────────────────

  /** Generate a representative default value from a JSON Schema property. */
  function defaultForProp(schema: PropSchema): unknown {
    if (schema.default !== undefined) return schema.default;
    switch (schema.type) {
      case "string":
        return schema.enum?.[0] ?? schema.oneOf?.[0]?.const ?? "";
      case "number":
      case "integer":
        return schema.minimum ?? 0;
      case "boolean":
        return false;
      case "array":
        return [];
      case "object": {
        const obj: Record<string, unknown> = {};
        if (schema.properties) {
          for (const [k, v] of Object.entries(schema.properties))
            obj[k] = defaultForProp(v as PropSchema);
        }
        return obj;
      }
    }
  }

  /** Build a default args object from a tool's inputSchema. */
  function defaultArgsFromSchema(
    schema: InputSchema | undefined,
  ): Record<string, unknown> {
    if (!schema?.properties) return {};
    const out: Record<string, unknown> = {};
    for (const [key, prop] of Object.entries(schema.properties))
      out[key] = defaultForProp(prop as PropSchema);
    return out;
  }

  /** Render per-property input fields inside the arg-fields container. */
  function renderArgFields(
    container: HTMLElement,
    schema: InputSchema | undefined,
    currentValues: Record<string, unknown>,
  ): void {
    container.innerHTML = "";
    if (!schema?.properties || Object.keys(schema.properties).length === 0)
      return;

    for (const [key, prop] of Object.entries(schema.properties)) {
      const p = prop as PropSchema;
      const value =
        key in currentValues ? currentValues[key] : defaultForProp(p);
      const required = schema.required?.includes(key) ?? false;

      const wrapper = document.createElement("div");
      wrapper.className = "row";

      const label = document.createElement("label");
      label.className = "label-inline";
      label.textContent = `${key}${required ? " *" : ""}`;

      let input: HTMLInputElement | HTMLSelectElement;

      if (p.type === "boolean") {
        const sel = document.createElement("select");
        sel.dataset.argKey = key;
        sel.dataset.argType = "boolean";
        ["false", "true"].forEach((v) => {
          const opt = document.createElement("option");
          opt.value = v;
          opt.textContent = v;
          if (String(value) === v) opt.selected = true;
          sel.appendChild(opt);
        });
        input = sel;
      } else if (p.type === "string" && (p.enum || p.oneOf)) {
        const choices = p.enum ?? p.oneOf?.map((o) => o.const) ?? [];
        const sel = document.createElement("select");
        sel.dataset.argKey = key;
        sel.dataset.argType = "string";
        choices.forEach((v) => {
          const opt = document.createElement("option");
          opt.value = v;
          opt.textContent = p.oneOf?.find((o) => o.const === v)?.title ?? v;
          if (String(value) === v) opt.selected = true;
          sel.appendChild(opt);
        });
        input = sel;
      } else {
        const inp = document.createElement("input");
        inp.dataset.argKey = key;
        inp.dataset.argType = p.type;
        inp.spellcheck = false;
        if (p.type === "number" || p.type === "integer") {
          inp.type = "number";
          if ((p as { minimum?: number }).minimum !== undefined)
            inp.min = String((p as { minimum?: number }).minimum);
          if ((p as { maximum?: number }).maximum !== undefined)
            inp.max = String((p as { maximum?: number }).maximum);
          if (p.type === "integer") inp.step = "1";
        } else if (p.type === "array" || p.type === "object") {
          inp.type = "text";
          inp.placeholder = p.type === "array" ? "[]" : "{}";
        } else {
          inp.type = "text";
        }
        inp.value =
          typeof value === "object"
            ? JSON.stringify(value)
            : String(value ?? "");
        input = inp;
      }

      label.appendChild(input);
      wrapper.appendChild(label);
      container.appendChild(wrapper);
    }
  }

  /** Read the values out of the rendered arg fields and return a plain object. */
  function readArgFields(container: HTMLElement): Record<string, unknown> {
    const out: Record<string, unknown> = {};
    container.querySelectorAll<HTMLElement>("[data-arg-key]").forEach((el) => {
      const key = el.dataset.argKey!;
      const type = el.dataset.argType!;
      const raw = (el as HTMLInputElement | HTMLSelectElement).value;
      switch (type) {
        case "number":
        case "integer":
          out[key] = raw === "" ? null : Number(raw);
          break;
        case "boolean":
          out[key] = raw === "true";
          break;
        case "array":
        case "object":
          try {
            out[key] = JSON.parse(raw);
          } catch {
            out[key] = raw;
          }
          break;
        default:
          out[key] = raw;
      }
    });
    return out;
  }

  // ── Playground init ───────────────────────────────────────────────────────

  function initPlayground(root: HTMLElement) {
    const defaultEndpoint = root.dataset.endpoint ?? "/api/mcp";

    const q = <T extends HTMLElement>(ref: string) =>
      root.querySelector<T>(`[data-ref="${ref}"]`)!;

    const endpointInput = q<HTMLInputElement>("endpoint-input");
    const badge = q("badge");
    const btnConnect = q<HTMLButtonElement>("btn-connect");
    const btnDisconnect = q<HTMLButtonElement>("btn-disconnect");
    const serverInfo = q("server-info");
    const toolsSection = q("tools-section");
    const toolsList = q("tools-list");
    const callSection = q("call-section");
    const toolSelect = q<HTMLSelectElement>("tool-name");
    const argFields = q("arg-fields");
    const rawRow = q("raw-row");
    const toolArgs = q<HTMLInputElement>("tool-args");
    const btnCall = q<HTMLButtonElement>("btn-call");
    const logEl = q("log");

    endpointInput.value = defaultEndpoint;

    // Stored tool schemas keyed by name
    const toolSchemas = new Map<string, InputSchema | undefined>();

    // ── Logging ────────────────────────────────────────────────────────────
    function log(msg: string, kind: "info" | "ok" | "err" = "info") {
      const line = document.createElement("div");
      line.className = `log-line log-${kind}`;
      const ts = new Date().toLocaleTimeString();
      line.textContent = `[${ts}] ${msg}`;
      logEl.prepend(line);
      while (logEl.children.length > 100) logEl.lastChild?.remove();
    }

    // ── Status ─────────────────────────────────────────────────────────────
    function setStatus(s: "idle" | "connecting" | "connected") {
      badge.className = `badge badge-${s}`;
      badge.textContent = {
        idle: "Disconnected",
        connecting: "Connecting…",
        connected: "Connected",
      }[s];
      btnConnect.disabled = s !== "idle";
      btnDisconnect.disabled = s !== "connected";
      btnCall.disabled = s !== "connected";
      endpointInput.disabled = s !== "idle";
    }

    // ── Client state ───────────────────────────────────────────────────────
    let client: MCPClient | null = null;

    // ── Connect ────────────────────────────────────────────────────────────
    async function connect() {
      const endpoint = endpointInput.value.trim() || defaultEndpoint;
      setStatus("connecting");
      client = new MCPClient({
        endpoint,
        clientName: "mcp-playground",
        clientVersion: "1.0.0",
        onNotification(method, params) {
          log(`← ${method} ${params ? JSON.stringify(params) : ""}`, "info");
        },
      });

      client.addEventListener("disconnect", () => {
        setStatus("idle");
        serverInfo.innerHTML = "";
        toolsSection.hidden = true;
        callSection.hidden = true;
        toolSchemas.clear();
        client = null;
      });

      try {
        const info = await client.connect();
        setStatus("connected");
        serverInfo.innerHTML = `<strong>${info.title ?? info.name}</strong> v${info.version}${info.description ? ` — ${info.description}` : ""}`;
        log(`Connected to ${info.name} v${info.version}`, "ok");
        log(
          `Capabilities: ${JSON.stringify(client.serverCapabilities)}`,
          "info",
        );
        await loadTools();
      } catch (err) {
        setStatus("idle");
        log(`Connection failed: ${err}`, "err");
        client = null;
      }
    }

    // ── Load tools ─────────────────────────────────────────────────────────
    async function loadTools() {
      if (!client) return;
      try {
        // Collect all pages
        const allTools: Tool[] = [];
        let cursor: string | undefined;
        do {
          const page = await client.listTools(cursor ? { cursor } : undefined);
          allTools.push(...page.tools);
          cursor = page.nextCursor;
        } while (cursor);

        toolsList.innerHTML = "";
        toolSelect.innerHTML = "";
        toolSchemas.clear();

        for (const t of allTools) {
          toolSchemas.set(t.name, t.inputSchema as InputSchema | undefined);

          const li = document.createElement("li");
          li.textContent = t.description
            ? `${t.name} — ${t.description}`
            : t.name;
          toolsList.appendChild(li);

          const opt = document.createElement("option");
          opt.value = t.name;
          opt.textContent = t.name;
          toolSelect.appendChild(opt);
        }

        toolsSection.hidden = false;
        callSection.hidden = false;
        refreshArgForm();
      } catch (err) {
        log(`tools/list failed: ${err}`, "err");
      }
    }

    // ── Arg form ───────────────────────────────────────────────────────────
    function refreshArgForm() {
      const name = toolSelect.value;
      const schema = toolSchemas.get(name);
      const hasProps = !!(
        schema?.properties && Object.keys(schema.properties).length > 0
      );

      if (hasProps) {
        const defaults = defaultArgsFromSchema(schema);
        renderArgFields(argFields, schema, defaults);
        argFields.hidden = false;
        rawRow.hidden = true;
        rawRow.style.display = "none";
      } else {
        argFields.innerHTML = "";
        argFields.hidden = true;
        rawRow.hidden = false;
        toolArgs.value = "{}";
      }
    }

    toolSelect.addEventListener("change", refreshArgForm);

    // ── Call tool ──────────────────────────────────────────────────────────
    async function callTool() {
      if (!client) return;
      const name = toolSelect.value;
      const schema = toolSchemas.get(name);
      const hasProps = !!(
        schema?.properties && Object.keys(schema.properties).length > 0
      );

      let args: unknown;
      if (hasProps) {
        args = readArgFields(argFields);
      } else {
        try {
          args = JSON.parse(toolArgs.value || "{}");
        } catch {
          log("Invalid JSON in arguments field.", "err");
          return;
        }
      }

      log(`→ tools/call ${name}(${JSON.stringify(args)})`, "info");
      try {
        const result = await client.callTool({
          name,
          arguments: args as Record<string, unknown>,
        });
        if (result.isError) {
          log(`← error: ${JSON.stringify(result.content)}`, "err");
        } else {
          const text = result.content
            .filter(
              (c): c is { type: "text"; text: string } => c.type === "text",
            )
            .map((c) => c.text)
            .join("\n");
          log(`← ${text || JSON.stringify(result.content)}`, "ok");
        }
      } catch (err) {
        log(`Call failed: ${err}`, "err");
      }
    }

    // ── Disconnect ─────────────────────────────────────────────────────────
    async function disconnect() {
      await client?.disconnect();
      setStatus("idle");
    }

    // ── Wire up ────────────────────────────────────────────────────────────
    btnConnect.addEventListener("click", connect);
    btnDisconnect.addEventListener("click", disconnect);
    btnCall.addEventListener("click", callTool);
  }

  document
    .querySelectorAll<HTMLElement>("[data-mcp-playground]")
    .forEach(initPlayground);
</script>

<style>
  .mcp-playground {
    margin-top: 2rem;
    font-family: inherit;
  }

  .row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .label-inline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: bold;
    flex: 1;
  }

  input[type="text"],
  input[type="number"],
  input[type="url"],
  select {
    font-family: monospace;
    font-size: 0.9rem;
    padding: 0.25rem 0.4rem;
    border: 1px solid currentColor;
    background: transparent;
    color: inherit;
    border-radius: 2px;
    flex: 1;
    min-width: 10rem;
  }

  input[type="number"] {
    min-width: 6rem;
    flex: 0 1 8rem;
  }

  input[type="url"] {
    min-width: 18rem;
    flex: 1;
  }

  input:disabled,
  select:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  button {
    padding: 0.25rem 0.75rem;
    border: 1px solid currentColor;
    background: transparent;
    color: inherit;
    cursor: pointer;
    border-radius: 2px;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  button:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  button:not(:disabled):hover {
    background: currentColor;
    color: canvas;
  }

  .badge {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    border: 1px solid currentColor;
    font-weight: bold;
    white-space: nowrap;
  }

  .badge-idle {
    opacity: 0.45;
  }
  .badge-connecting {
    color: darkorange;
  }
  .badge-connected {
    color: green;
  }

  .server-info {
    margin-bottom: 1rem;
    font-size: 0.9rem;
    min-height: 1.2em;
  }

  .tools-list {
    margin: 0.5rem 0 1rem;
    padding-left: 1.25rem;
    font-size: 0.9rem;
  }

  .arg-fields {
    margin-bottom: 0.5rem;
  }

  .log {
    font-family: monospace;
    font-size: 0.8rem;
    border: 1px solid currentColor;
    padding: 0.5rem;
    height: 14rem;
    overflow-y: auto;
    border-radius: 2px;
    opacity: 0.85;
  }

  .log-line {
    margin: 0.1rem 0;
  }
  .log-ok {
    color: green;
  }
  .log-err {
    color: red;
  }
</style>
